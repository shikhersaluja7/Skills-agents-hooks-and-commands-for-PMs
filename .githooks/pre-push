#!/bin/sh
# pre-push hook: Final safety net before pushing to remote.
#   1. Verify .github/ and .claude/ are still in sync (catches bypassed commits)
#   2. Verify README/user-guide skill tables are up to date
#   3. Run humanizer check on every .md file in commits being pushed
#   4. Run secrets check on every file (any extension) in commits being pushed
# Blocks the push on any failure. Run `git push --no-verify` only with explicit user intent.

# Detect PowerShell
if command -v pwsh >/dev/null 2>&1; then
    PWSH="pwsh"
elif command -v powershell >/dev/null 2>&1; then
    PWSH="powershell"
else
    echo "WARNING: PowerShell not found. Skipping pre-push checks."
    exit 0
fi

# Step 1: Sync state must be clean (dry run; non-zero changes => block)
echo "[pre-push] Step 1/4: Verifying .github/ and .claude/ are in sync..."
SYNC_OUT=$($PWSH -NoProfile -ExecutionPolicy Bypass -File "./scripts/sync-skills.ps1" 2>&1)
echo "$SYNC_OUT"
if echo "$SYNC_OUT" | grep -q "out-of-sync"; then
    echo "[pre-push] Sync drifted. Run: powershell -File ./scripts/sync-skills.ps1 -Apply, then commit, then push."
    exit 1
fi

# Step 2: Doc tables must be up to date
echo "[pre-push] Step 2/4: Verifying user guides and README skill tables..."
DOC_OUT=$($PWSH -NoProfile -ExecutionPolicy Bypass -File "./scripts/update-docs.ps1" 2>&1)
echo "$DOC_OUT"
if echo "$DOC_OUT" | grep -q "need updating"; then
    echo "[pre-push] Doc tables are stale. Run: powershell -File ./scripts/update-docs.ps1 -Apply, then commit, then push."
    exit 1
fi

# Determine the range of commits being pushed.
# Prefer the upstream tracking branch; fall back to origin/<current branch>; final fallback is full history.
UPSTREAM=""
if git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1; then
    UPSTREAM='@{u}'
else
    BRANCH=$(git rev-parse --abbrev-ref HEAD)
    if git rev-parse "origin/$BRANCH" >/dev/null 2>&1; then
        UPSTREAM="origin/$BRANCH"
    fi
fi

# Step 3: Humanizer check on every .md file in unpushed commits
echo "[pre-push] Step 3/4: Running humanizer check on .md files being pushed..."

if [ -n "$UPSTREAM" ]; then
    MD_FILES=$(git diff --name-only "$UPSTREAM"..HEAD -- '*.md' 2>/dev/null)
else
    MD_FILES=$(git ls-tree -r --name-only HEAD -- '*.md' 2>/dev/null)
fi

if [ -z "$MD_FILES" ]; then
    echo "[pre-push] No .md files in unpushed commits. Skipping humanizer."
else
    echo "[pre-push] Humanizing $(echo "$MD_FILES" | wc -l | tr -d ' ') .md file(s)..."
    FILES_ARG=$(echo "$MD_FILES" | tr '\n' ',' | sed 's/,$//')
    $PWSH -NoProfile -ExecutionPolicy Bypass -File "./scripts/humanizer-check.ps1" -Files $FILES_ARG

    if [ $? -ne 0 ]; then
        echo "[pre-push] Humanizer check FAILED. Fix the violations above, commit, then push again."
        exit 1
    fi
fi

# Step 4: Secrets check on every file (any extension) in unpushed commits
echo "[pre-push] Step 4/4: Running secrets check on files being pushed..."

if [ -n "$UPSTREAM" ]; then
    ALL_FILES=$(git diff --name-only "$UPSTREAM"..HEAD 2>/dev/null)
else
    ALL_FILES=$(git ls-tree -r --name-only HEAD 2>/dev/null)
fi

if [ -z "$ALL_FILES" ]; then
    echo "[pre-push] No files in unpushed commits. Skipping secrets check."
else
    echo "[pre-push] Scanning $(echo "$ALL_FILES" | wc -l | tr -d ' ') file(s) for secrets..."
    SECRETS_ARG=$(echo "$ALL_FILES" | tr '\n' ',' | sed 's/,$//')
    $PWSH -NoProfile -ExecutionPolicy Bypass -File "./scripts/secrets-check.ps1" -Files $SECRETS_ARG

    if [ $? -ne 0 ]; then
        echo "[pre-push] Secrets check FAILED. Remove the leak (or extend the allowlist), commit, then push again."
        exit 1
    fi
fi

echo "[pre-push] All checks passed. Pushing."
exit 0
