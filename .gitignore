# Python virtual environment
.venv/
__pycache__/
*.pyc
*.pyo

# Input source material (user-provided, never committed)
input/

# Output artifacts (generated per-project, ephemeral)
output/

# Sample data (validation fixtures, kept local; folder is tracked via .gitkeep)
sample-data/*
!sample-data/.gitkeep

# Logs
*.log

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo

# OneDrive temp files
~$*.docx
~$*.doc

# Port staging (temporary)
port-staging/
/port-staging/

# Claude Code local settings (per-machine, not shared)
.claude/settings.local.json
